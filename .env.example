# --- Required for any non-dev deployment (server refuses to start without) ---
WTRMLN_BASIC_AUTH=team:change-me            # HTTP Basic auth (user:pass) for the whole app
WTRMLN_VAULT_KEY=                            # Fernet key from your secrets manager:
                                             #   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- Required for real agent runs ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Optional ---
WTRMLN_DEV_MODE=0                # 1 = local dev only: skips the two required vars above
WTRMLN_MOCK_AGENT=0              # 1 = scripted demo agent, no API key needed
WTRMLN_AGENT_MODEL=claude-opus-4-8
WTRMLN_MAX_SESSIONS=3            # concurrent connection sessions
WTRMLN_SESSION_TIMEOUT=1800      # seconds before a session is stopped
WTRMLN_CHROMIUM_PATH=            # explicit chromium binary if Playwright's isn't installed
WTRMLN_PROXY_INSECURE_TLS=0      # 1 = dev sandboxes with TLS-intercepting proxy and no CA install
