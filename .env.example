# Required for real agent runs (omit and set WTRMLN_MOCK_AGENT=1 for demo mode)
ANTHROPIC_API_KEY=sk-ant-...

# Optional
WTRMLN_AGENT_MODEL=claude-opus-4-8   # model driving the connection agent
WTRMLN_MOCK_AGENT=0                  # 1 = scripted demo, no API key needed
WTRMLN_VAULT_KEY=                    # Fernet key; auto-generated to data/vault.key if unset
WTRMLN_CHROMIUM_PATH=                # explicit chromium binary if Playwright's isn't installed
